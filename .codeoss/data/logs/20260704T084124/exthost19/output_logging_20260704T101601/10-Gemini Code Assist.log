number_input(\n            f\"Enter {x_column}\",\n            float(X.min()),\n            float(X.max()),\n            float(X.mean())\n        )\n\n        prediction = model.predict([[new_value]])\n\n        st.success(f\"Predicted {y_column}: {prediction[0]:.2f}\")\n\nelse:\n    st.info(\"Please upload a CSV file.\")"},{"isSelected":true},{}]},"otherFiles":[{"codeLanguage":"python","filePath":"add.py","includedReason":"RECENTLY_OPENED","segments":[{"content":"a=1\nb=2\nc=a+b\nprint(c)"}]},{"codeLanguage":"python","filePath":"app.py","includedReason":"COLOCATED","segments":[{"content":"import streamlit as st\n\nst.set_page_config(page_title=\"Addition App\")\n\nst.title(\"Simple Addition Application\")\n\nst.write(\"Deployed from GCP Cloud Shell to GitHub and Streamlit Cloud\")\n\nnumber1 = st.number_input(\"Enter first number\")\n\nnumber2 = st.number_input(\"Enter second number\")\n\nif st.button(\"Calculate Addition\"):\n    result = number1 + number2\n    st.success(\"Addition Result = \" + str(result))"}]}]},"metadata":{"duetProject":"cloudshell-gca","ideName":"Code OSS for Cloud Shell","ideType":"CLOUD_SHELL","ideVersion":"1.109.5-cde","platform":"LINUX_AMD64","pluginType":"CLOUD_CODE","pluginVersion":"2.86.0"},"project":"cloudshell-gca","requestId":"cloudcode-928260283-45d35a25-921c-4e86-bb12-d2656c4a2f05","userContext":{}}
